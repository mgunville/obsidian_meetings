VAULT_PATH=~/Notes/notes-vault/
RECORDINGS_PATH=~/Notes/recordings

# Optional overrides
# MEETINGCTL_DOTENV_PATH=~/.config/meetingctl/env
# MEETINGCTL_ENV_PROFILE=secure
# MEETINGCTL_USE_1PASSWORD=auto
# DEFAULT_MEETINGS_FOLDER=Meetings
# MEETINGCTL_ARTIFACTS_ROOT=Meetings/_artifacts
# MEETINGCTL_NOTE_TEMPLATE_PATH=~/Notes/notes-vault/System/Templates/icalBuddy/Meeting.md
# MEETINGCTL_MATCH_WINDOW_MINUTES=30
# Ingest calendar matching defaults (Hazel/live ingest): match against current time only.
# Forward search loops: now -> +5m -> +10m (max +10).
# Backward loops: now -> -5m -> -10m -> -15m (max -15).
# MEETINGCTL_INGEST_FORWARD_WINDOW_MINUTES=10
# MEETINGCTL_INGEST_BACKWARD_WINDOW_MINUTES=15
# MEETINGCTL_INGEST_MIN_AGE_SECONDS=15
# MEETINGCTL_BACKFILL_EXTENSIONS=wav
# MEETINGCTL_STATE_FILE=~/.local/state/meetingctl/current.json
# MEETINGCTL_PROCESS_QUEUE_FILE=~/.local/state/meetingctl/process_queue.jsonl
# MEETINGCTL_PROCESSED_JOBS_FILE=~/.local/state/meetingctl/processed_jobs.jsonl
# MEETINGCTL_PROCESS_QUEUE_FAILURE_MODE=dead_letter
# MEETINGCTL_PROCESS_QUEUE_DEAD_LETTER_FILE=~/.local/state/meetingctl/process_queue.deadletter.jsonl
# MEETINGCTL_PROCESS_QUEUE_MAX_JOBS=3
# MEETINGCTL_PROCESS_QUEUE_DRAIN_PASSES=6
# MEETINGCTL_AUDIO_HIJACK_START_SCRIPT=/absolute/path/to/config/audio_hijack/scripts/start_teams_mic.ahcommand
# MEETINGCTL_AUDIO_HIJACK_STOP_SCRIPT=/absolute/path/to/config/audio_hijack/scripts/stop_teams_mic.ahcommand
# MEETINGCTL_TRANSCRIPTION_BACKEND=whisper
# MEETINGCTL_TRANSCRIPTION_MODEL=base
# MEETINGCTL_TRANSCRIPTION_TIMEOUT_SECONDS=1800
# MEETINGCTL_WHISPERX_COMPUTE_TYPE=int8
# MEETINGCTL_WHISPERX_VAD_METHOD=silero
# MEETINGCTL_TRANSCRIPTION_FALLBACK_TO_WHISPER=1
# MEETINGCTL_WHISPERX_MODEL_PATH=/absolute/path/to/config/models/whisperx/faster-whisper-base
# MEETINGCTL_ICALBUDDY_BIN=/usr/local/bin/icalBuddy
# MEETINGCTL_ICALBUDDY_CALENDAR=Work
# Optional: pin filename-derived recording timestamps to a stable IANA TZ
# (prevents travel-timezone drift for names like 20260210_1130-*.wav)
# MEETINGCTL_RECORDING_FILENAME_TIMEZONE=America/Chicago
# Optional: default timezone for Voice Memos filename stamps
# (names like "20260209 143519-XXXX.m4a"). If unset, local timezone is used.
# MEETINGCTL_VOICEMEMO_FILENAME_TIMEZONE=America/Chicago
# Optional: newline-delimited incident manifest for files that should be treated as UTC.
# Entries can be basenames or absolute paths.
# MEETINGCTL_VOICEMEMO_UTC_MANIFEST=~/Notes/audio/voice_memo_utc_manifest.txt
# LLM summary provider (currently supported): Anthropic
# ANTHROPIC_API_KEY=
# Optional 1Password secret reference (resolved at runtime via `op read`)
# MEETINGCTL_ANTHROPIC_API_KEY_OP_REF=op://Private/Anthropic/api_key
# Optional: override Anthropic summary model(s), comma-separated fallback order.
# MEETINGCTL_SUMMARY_MODEL=claude-sonnet-4-6,claude-3-5-sonnet-latest
# Optional: use macOS trust roots via truststore for Anthropic TLS (recommended on managed networks).
# MEETINGCTL_SUMMARY_USE_SYSTEM_TRUST=1
# Optional: custom CA bundle path for Anthropic TLS.
# MEETINGCTL_SSL_CA_BUNDLE=/absolute/path/to/cacert.pem
# Optional: retries for transient summary API failures (e.g., 429/529 overload).
# MEETINGCTL_SUMMARY_REQUEST_RETRIES=2
# MEETINGCTL_SUMMARY_RETRY_BASE_SECONDS=2
# Optional: write <audio-file>.done.json sidecar on successful processing (`sidecar` or `none`).
# MEETINGCTL_AUDIO_DONE_MODE=sidecar
# Optional local/no-API override for testing summaries:
# MEETINGCTL_PROCESSING_SUMMARY_JSON={"minutes":"Test summary","decisions":[],"action_items":[]}
